<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.yite.standardtest.mapper.OrderMapper">


    <select id="selectByOrderNo" parameterType="string" resultType="com.yite.standardtest.entity.OrderEntity">
        SELECT *
        FROM t_order
        WHERE order_no = #{orderNo}
    </select>


</mapper>
